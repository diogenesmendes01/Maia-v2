{
  "name": "maia-v2",
  "version": "0.1.0",
  "description": "Maia — Assistente financeira inteligente via WhatsApp - PF + 8 PJs",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "tsx scripts/setup.ts",
    "pessoa:add": "tsx scripts/pessoa-add.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "import:ofx": "tsx scripts/import-ofx.ts",
    "import:list": "tsx scripts/import-review.ts list",
    "import:show": "tsx scripts/import-review.ts show",
    "import:apply": "tsx scripts/import-review.ts apply",
    "dlq": "tsx scripts/dlq.ts",
    "backup": "tsx scripts/backup.ts",
    "restore:test": "tsx scripts/restore-test.ts",
    "embeddings:rebuild": "tsx scripts/embeddings-rebuild.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:leak": "vitest run tests/integration/leak.spec.ts tests/integration/repos-leak.spec.ts tests/unit/cross-entity.spec.ts tests/unit/constitutional.spec.ts",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.0",
    "bullmq": "^5.20.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.1.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "openai": "^4.70.0",
    "pdfmake": "^0.2.23",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfmake": "^0.2.13",
    "@types/pg": "^8.11.10",
    "@types/qrcode-terminal": "^0.12.2",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
