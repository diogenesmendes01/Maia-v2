# =====================================================================
# Maia — Variáveis de ambiente
# Copie para .env e preencha. NUNCA comite o .env real.
# =====================================================================

NODE_ENV=development
TZ=America/Sao_Paulo
APP_PORT=3000
LOG_LEVEL=info

# ---- Banco de dados ----
POSTGRES_USER=maia
POSTGRES_PASSWORD=trocar_senha_forte
POSTGRES_DB=maia
POSTGRES_PORT=5432
DATABASE_URL=postgres://maia:trocar_senha_forte@localhost:5432/maia

# ---- Redis ----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- Claude (Anthropic) ----
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_MAIN=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# ---- OpenAI (Whisper) ----
OPENAI_API_KEY=sk-...
WHISPER_MODEL=whisper-1

# ---- Embeddings (Voyage AI ou OpenAI) ----
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSIONS=1024

# ---- WhatsApp / Baileys ----
BAILEYS_AUTH_DIR=./.baileys-auth
WHATSAPP_NUMBER_MAIA=+5511000000000
MAIA_DISPLAY_NAME=Maia

# ---- Governança ----
VALOR_LIMITE_SEM_CONFIRMACAO=1000.00
VALOR_LIMITE_DURO=10000.00
APROVAR_MENSAGENS_PROATIVAS=true

# ---- Owner (você) ----
OWNER_TELEFONE_WHATSAPP=+5511999999999
OWNER_NOME=Mendes
