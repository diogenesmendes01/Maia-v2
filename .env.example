# =====================================================================
# Maia — Variáveis de ambiente
# Copie para .env e preencha. NUNCA comite o .env real.
# =====================================================================

NODE_ENV=development
TZ=America/Sao_Paulo
APP_PORT=3000
LOG_LEVEL=info

# ---- Banco de dados ----
POSTGRES_USER=maia
POSTGRES_PASSWORD=trocar_senha_forte
POSTGRES_DB=maia
POSTGRES_PORT=5432
DATABASE_URL=postgres://maia:trocar_senha_forte@localhost:5432/maia

# ---- Redis ----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- LLM Provider ----
# anthropic = direct Anthropic API (legacy default)
# openrouter = unified gateway (Claude / GPT / Llama / DeepSeek / Gemini ...)
LLM_PROVIDER=openrouter

# Required when LLM_PROVIDER=anthropic:
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_MAIN=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# Required when LLM_PROVIDER=openrouter (recommended):
OPENROUTER_API_KEY=sk-or-...
# IMPORTANTE: o slug usa . (ponto) na versão, não - (dash). Ex: 4.6, não 4-6.
# IMPORTANTE: a Maia REQUER tool-calling. Lista filtrada:
#   https://openrouter.ai/models?supported_parameters=tools
OPENROUTER_MODEL_MAIN=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL_FAST=anthropic/claude-haiku-4.5
# Operator can change models at runtime via /dashboard/llm-settings (no restart).

# ---- OpenAI (Whisper) ----
OPENAI_API_KEY=sk-...
WHISPER_MODEL=whisper-1

# ---- Embeddings (voyage | openai | cohere) ----
# Defina o provider e a chave correspondente. EMBEDDING_MODEL deve combinar
# com o provider (prefixos: voyage-*, text-embedding-*, embed-*).
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSIONS=1024
VOYAGE_API_KEY=
COHERE_API_KEY=

# ---- WhatsApp / Baileys ----
BAILEYS_AUTH_DIR=./.baileys-auth
WHATSAPP_NUMBER_MAIA=+5511000000000
MAIA_DISPLAY_NAME=Maia

# ---- Governança ----
VALOR_LIMITE_SEM_CONFIRMACAO=1000.00
VALOR_LIMITE_DURO=10000.00
APROVAR_MENSAGENS_PROATIVAS=true

# ---- Owner (você) ----
OWNER_TELEFONE_WHATSAPP=+5511999999999
OWNER_NOME=Mendes

# ---- Observabilidade / Alertas ----
# Threshold diário (USD) para o cost monitor. Acima dispara alerta.
DAILY_LLM_USD_THRESHOLD=5
# Canais de alerta: log,email,telegram (separados por vírgula)
# ALERT_CHANNELS=log,email
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# ALERT_EMAIL_TO=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ---- Backup ----
# BACKUP_DIR=./backups
# BACKUP_RETENTION_LOCAL_DAYS=7
# BACKUP_S3_BUCKET=

# ---- Feature flags ----
# View-once for sensitive replies (saldos, comparativos). Default false.
# When true: outbound text replies for turns that ran a tool flagged
# `sensitive: true` (query_balance, compare_entities) are sent with the
# viewOnce flag, gated by pessoa.preferencias.balance_view_once.
# FEATURE_VIEW_ONCE_SENSITIVE=false

# PDF reports (extrato + comparativo) sent as WhatsApp documents. Default false.
# When true: the LLM can invoke `generate_report` to produce a PDF and send it
# with an LLM-written caption. View-once is NEVER applied to PDFs (spec B3b §11).
# FEATURE_PDF_REPORTS=false

# Outbound voice notes via OpenAI TTS. Default false.
# When true: voice-in conversations get voice-out replies (≤400 chars only).
# Text-in conversations always get text. PDF turns (B3b) always get PDF.
# Reuses OPENAI_API_KEY already configured for Whisper.
# FEATURE_OUTBOUND_VOICE=false
